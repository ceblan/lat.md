#!/usr/bin/env bash
set -euo pipefail

# Rebase local patch branch on top of upstream and run focused checks.
# Defaults can be overridden via env vars or flags.
#
# Usage:
#   scripts/up-patch
#   scripts/up-patch --remote upstream --base main --branch patch/nested-lat-repo-sync
#
# Env overrides:
#   UPSTREAM_REMOTE, UPSTREAM_BASE, PATCH_BRANCH

UPSTREAM_REMOTE="${UPSTREAM_REMOTE:-upstream}"
UPSTREAM_BASE="${UPSTREAM_BASE:-main}"
PATCH_BRANCH="${PATCH_BRANCH:-patch/nested-lat-repo-sync}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --remote)
      UPSTREAM_REMOTE="$2"
      shift 2
      ;;
    --base)
      UPSTREAM_BASE="$2"
      shift 2
      ;;
    --branch)
      PATCH_BRANCH="$2"
      shift 2
      ;;
    -h|--help)
      sed -n '1,40p' "$0"
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

echo "==> Ensuring clean working tree"
if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "Working tree has uncommitted changes. Commit/stash first." >&2
  exit 1
fi

echo "==> Fetching ${UPSTREAM_REMOTE}"
git fetch "${UPSTREAM_REMOTE}"

echo "==> Switching to ${PATCH_BRANCH}"
git checkout "${PATCH_BRANCH}"

echo "==> Rebasing onto ${UPSTREAM_REMOTE}/${UPSTREAM_BASE}"
git rebase "${UPSTREAM_REMOTE}/${UPSTREAM_BASE}"

echo "==> Running checks"
pnpm build
pnpm test tests/hook.test.ts
lat check

echo
echo "Done. Patch branch is rebased and checks passed."
echo "Current branch: $(git branch --show-current)"
